# ── Plugin build (3DS side) ────────────────────────────────────────────────────
# UDP port used by the plugin to send packets to the server
UDP_PORT=5005

# ── Server (python server/main.py) ────────────────────────────────────────────
DRPC_UDP_HOST=0.0.0.0
DRPC_UDP_PORT=5005
DRPC_WS_HOST=0.0.0.0
DRPC_WS_PORT=8765
DRPC_TITLE_API_TEMPLATE=https://api.nlib.cc/ctr/{tid}
DRPC_API_TIMEOUT_SEC=5.0
# Seconds without a heartbeat before the RPC is cleared (plugin sends one every 10s)
DRPC_WATCHDOG_TIMEOUT_SEC=25

# ── Client (python client/main.py) ────────────────────────────────────────────
DRPC_SERVER_WS_URL=wss://api.etsukow.com

# REQUIRED — your Discord application ID (developer.discord.com)
DRPC_DISCORD_APP_ID=1480019559606911057

DRPC_FALLBACK_ICON=nintendo_3ds
DRPC_RPC_MIN_INTERVAL=15
